# Root level gitignore for the entire project

# Editor and IDE
.vscode/
.idea/
*.code-workspace
*.iml

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Backend specific
backend/chroma_db/
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/ecommerce.db
backend/agent_graph.png

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Node modules (Frontend)
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/.eslintcache

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Documentation (generated)
*.md.backup

# Project specific
test_*.py
debug_*.py

# Sensitive data
secrets/
credentials/
*.key
api_keys.txt
