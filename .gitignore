# Root level gitignore for the entire project

# Editor and IDE
.vscode/
.idea/
*.code-workspace
*.iml

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Documentation (generated)
*.md.backup

# Project specific
test_*.py
debug_*.py

# Sensitive data
secrets/
credentials/
*.key
api_keys.txt

